# URL del backend Java (web-service-cashi)
BACKEND_URL=http://localhost:8080

# Token compartido con el backend (igual que OSIPTEL)
WORKER_TOKEN=change-me-shared-secret

# Cuántos números pedir al backend por ciclo
BATCH_SIZE=10

# Intervalo entre ciclos de polling (ms)
POLL_INTERVAL_MS=30000

# Timeout máximo por consulta a WhatsApp (ms)
CHECK_TIMEOUT_MS=10000

# Ruta al archivo de sesión de Baileys (persistido entre reinicios)
WA_AUTH_FILE=./wa-auth.json

# Nivel de log: trace | debug | info | warn | error
LOG_LEVEL=info
